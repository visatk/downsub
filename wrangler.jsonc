{
	"$schema": "node_modules/wrangler/config-schema.json",
	"name": "cybercoderbd",
	"main": "worker/index.ts",
	"compatibility_date": "2026-05-25",
	"assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
    "run_worker_first": [
      "/api/*",
      "/sitemap.xml",
      "/robots.txt"
    ]
  },
	"observability": {
		"enabled": true
	},
	"upload_source_maps": true,
	"compatibility_flags": [
		"nodejs_compat"
	],
	"ai": {
    "binding": "AI"
  },
  "placement": {
    "mode": "smart"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "cybercoderbd",
      "database_id": "42b9b4fc-c442-40be-8b89-df0cca15a0c6"
    }
  ],
  "analytics_engine_datasets": [
    {
      "binding": "ANALYTICS",
      "dataset": "ANALYTICS"
    }
  ]
}
